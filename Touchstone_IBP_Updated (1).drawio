    <!-- ══════════════════════════════════════════════════════════════════
         RIGHT PANELS — DATA / ACCESS / RISKS / MITIGATIONS
    ══════════════════════════════════════════════════════════════════ -->
    <!-- DATA -->
    <mxCell id="panel_data" value="&lt;b style='color:#1E3A5F;'&gt;DATA&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:9px;'&gt;ELT, EP Curves, Loss Summary, HAZ&lt;br&gt;SOR Excel output:&lt;br&gt;• AGG table (SUMIFS/year)&lt;br&gt;• OCC table (MAXIFS/year)&lt;br&gt;• EP Summary (LARGE-based)&lt;br&gt;• Top 5 Events (XLOOKUP)&lt;br&gt;• ModelCodeRef tab&lt;br&gt;Combined: one sheet per peril&lt;br&gt;N_years: 10,000 / 500,000 (TR)&lt;br&gt;Filter: CatalogTypeCode=STC only&lt;br&gt;Internal CRC — AIR Worldwide source&lt;br&gt;Excel (.xlsx) reports generated in-memory&lt;br&gt;and served as direct browser downloads&lt;br&gt;No server-side persistence of output files&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#1E3A5F;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="1165" y="150" width="190" height="210" as="geometry"/>
    </mxCell>
    <!-- ACCESS -->
    <mxCell id="panel_access" value="&lt;b style='color:#1E3A5F;'&gt;ACCESS&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:9px;'&gt;3 service accounts (dev/uat/prod)&lt;br&gt;automation-dev (DEV)&lt;br&gt;automationservice (UAT)&lt;br&gt;automation-prod (PROD)&lt;br&gt;Domain: crcins.air&lt;br&gt;NTLM authentication&lt;br&gt;APP_ENV controls account selection&lt;br&gt;All API calls audit logged&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#1E3A5F;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="1165" y="370" width="190" height="140" as="geometry"/>
    </mxCell>
    <!-- RISKS -->
    <mxCell id="panel_risks" value="&lt;b style='color:#991B1B;'&gt;RISKS&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:9px;'&gt;• SSL verify=False — corp cert not in trust store;&lt;br&gt;  all Touchstone API calls bypass TLS validation&lt;br&gt;  (explicitly flagged by security review)&lt;br&gt;• ResultSetCount may mismatch actual results&lt;br&gt;• CatalogTypeCode=RDS terrorism —&lt;br&gt;  STC filter produces empty results;&lt;br&gt;  catalog type pending Jennifer confirmation&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#DC2626;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="1165" y="520" width="190" height="200" as="geometry"/>
    </mxCell>
    <!-- MITIGATIONS -->
    <mxCell id="panel_mitig" value="&lt;b style='color:#065F46;'&gt;MITIGATIONS&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:9px;'&gt;• Azure App Service — handles TLS, routing,&lt;br&gt;  and access control natively&lt;br&gt;• Azure Key Vault — credential storage for prod&lt;br&gt;• Entra ID SSO — analyst authentication (pending IT)&lt;br&gt;• FileSystemCache — shared worker cache&lt;br&gt;• Gunicorn gevent workers — no SOAP blocking&lt;br&gt;• Sequential NTLM fetch — threading adds overhead&lt;br&gt;  for NTLM handshakes; sequential is faster&lt;br&gt;• ThreadPoolExecutor for model-batch only&lt;br&gt;  (lightweight calls, parallelism beneficial)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="1165" y="728" width="190" height="210" as="geometry"/>
    </mxCell>

