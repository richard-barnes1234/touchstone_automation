    <!-- Core Functions -->
    <mxCell id="corefx" value="&lt;b&gt;Core Functions — Enterprise&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:9px;'&gt;🔑 Azure Sentinel &nbsp; 🏆 Log Analytics&lt;br&gt;📋 Log Prometheus &nbsp; 🔐 AAD Identity&lt;br&gt;📊 AppGateway Diagnostic&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1160" y="460" width="275" height="80" as="geometry"/>
    </mxCell>

    <!-- ══════════════ RIGHT PANELS ══════════════ -->
    <!-- DATA -->
    <mxCell id="panel_data_hdr" value="DATA" style="rounded=1;fillColor=#9B7FD4;strokeColor=#6B4FA4;fontColor=#FFFFFF;fontStyle=1;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="1530" y="295" width="360" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="panel_data_body" value="&lt;span style='font-size:10px;'&gt;• ELT, EP Curves, Loss Summary, HAZ results from Touchstone API (read-only, no write-back)&lt;br&gt;• Excel (.xlsx) SOR reports generated in-memory and served as direct analyst browser downloads&lt;br&gt;• No output files persisted server-side — reports are ephemeral&lt;br&gt;• API audit log written to disk: logs/touchstone_api_audit.log&lt;br&gt;• Data classification: Class 1 — catastrophe modeling loss data, internal CRC use only&lt;br&gt;• No PII or sensitive personal data processed&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EFFF;strokeColor=#9B7FD4;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
      <mxGeometry x="1530" y="331" width="360" height="130" as="geometry"/>
    </mxCell>

    <!-- ACCESS -->
    <mxCell id="panel_access_hdr" value="ACCESS" style="rounded=1;fillColor=#9B7FD4;strokeColor=#6B4FA4;fontColor=#FFFFFF;fontStyle=1;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="1530" y="471" width="360" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="panel_access_body" value="&lt;span style='font-size:10px;'&gt;• Analysts access via managed browser — HTTPS only&lt;br&gt;• Entra ID SSO planned (pending IT App Registration)&lt;br&gt;• 3 NTLM service accounts (domain: crcins.air):&lt;br&gt;&nbsp;&nbsp;— automation-dev (DEV environment)&lt;br&gt;&nbsp;&nbsp;— automationservice (UAT environment)&lt;br&gt;&nbsp;&nbsp;— automation-prod (PROD environment)&lt;br&gt;• APP_ENV variable controls which account is active&lt;br&gt;• All API calls audit logged with account, timestamp, duration&lt;br&gt;• Credentials stored in Azure Key Vault (prod)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EFFF;strokeColor=#9B7FD4;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
      <mxGeometry x="1530" y="507" width="360" height="160" as="geometry"/>
    </mxCell>

    <!-- RISKS -->
    <mxCell id="panel_risks_hdr" value="RISKS" style="rounded=1;fillColor=#9B7FD4;strokeColor=#6B4FA4;fontColor=#FFFFFF;fontStyle=1;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="1530" y="677" width="360" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="panel_risks_body" value="&lt;span style='font-size:10px;'&gt;• SSL verify=False — Touchstone API cert not in CRC trust store; all API calls bypass TLS certificate validation (flagged by security review — Billy)&lt;br&gt;• ResultSetCount in API response may not match actual row count — pagination edge case&lt;br&gt;• Terrorism analyses may return empty results if run against RDS catalog (not STC) — pending Jennifer confirmation&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EFFF;strokeColor=#9B7FD4;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
      <mxGeometry x="1530" y="713" width="360" height="120" as="geometry"/>
    </mxCell>

    <!-- MITIGATIONS -->
    <mxCell id="panel_mitig_hdr" value="MITIGATIONS" style="rounded=1;fillColor=#9B7FD4;strokeColor=#6B4FA4;fontColor=#FFFFFF;fontStyle=1;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
      <mxGeometry x="1530" y="843" width="360" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="panel_mitig_body" value="&lt;span style='font-size:10px;'&gt;• Azure App Service handles TLS termination, HTTPS enforcement, and routing natively — no reverse proxy required&lt;br&gt;• Azure Key Vault stores all service account credentials in production&lt;br&gt;• Entra ID SSO provides identity-based access control (pending IT)&lt;br&gt;• NSG restricts inbound to port 443 only&lt;br&gt;• Corporate firewall enforces HTTPS-only outbound&lt;br&gt;• All Touchstone API calls logged via @audited_call decorator&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EFFF;strokeColor=#9B7FD4;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
      <mxGeometry x="1530" y="879" width="360" height="150" as="geometry"/>
    </mxCell>

    <!-- ══════════════ CONNECTORS ══════════════ -->
    <!-- User → MFA -->
    <mxCell id="c_user_mfa" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CC0000;strokeWidth=2;" edge="1" parent="1" source="crc_users" target="mfa_int">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- MFA → Firewall (HTTPS) -->
    <mxCell id="c_mfa_fw" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CC0000;strokeWidth=2;fontColor=#CC0000;fontSize=9;" edge="1" parent="1" source="mfa_int" target="corp_firewall">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Firewall → App Service -->
    <mxCell id="c_fw_app" value="HTTPS/443" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#007700;strokeWidth=2;fontColor=#007700;fontSize=9;" edge="1" parent="1" source="corp_firewall" target="app_service">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- App Service → AIR Touchstone (SOAP/NTLM) -->
    <mxCell id="c_app_air" value="SOAP/NTLM" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CC0000;strokeWidth=2;fontColor=#CC0000;fontSize=9;dashed=1;" edge="1" parent="1" source="app_service" target="air_partner">
